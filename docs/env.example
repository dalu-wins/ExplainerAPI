# Provider selection
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4

# Shared LLM settings
LLM_MAX_TOKENS=1200
LLM_TIMEOUT=60
LLM_TEMPERATURE=0.2

# This server's own API key auth
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Specify multiple by separating with commas
API_KEYS=your-secret-key-here

# Debug
DEBUG_RAW_OUTPUT=false

# Rate limiting per ExplainerAPI API-Key
RATE_LIMIT_PER_MINUTE=2
